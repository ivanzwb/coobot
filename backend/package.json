{
  "name": "biosbot-backend",
  "version": "1.0.0",
  "description": "BiosBot Agent System Backend",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push:sqlite --config drizzle.config.ts",
    "db:migrate:remove-agent-role": "tsx scripts/migrate-remove-agent-role-column-20260320.ts",
    "db:migrate:agent-skill-permissions": "tsx scripts/migrate-agent-skill-permission-bindings-20260320.ts",
    "db:migrate:skill-runtime-version": "tsx scripts/migrate-skill-runtime-version-20260320.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/init.ts",
    "db:seed:demo": "tsx src/db/seed-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "config": "^4.4.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.29.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.2",
    "mammoth": "^1.6.0",
    "node-config": "^0.0.2",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/node": "^20.11.16",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.20.14",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0"
  }
}
