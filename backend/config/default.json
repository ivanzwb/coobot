{
  "server": {
    "port": 3002,
    "host": "localhost"
  },
  "database": {
    "path": "./data/biosbot.db"
  },
  "vectorDb": {
    "path": "./data/vectordb"
  },
  "workspace": {
    "path": "./workspace"
  },
  "skills": {
    "path": "../skills",
    "toolBindings": {
      "skill-code": ["read_file", "write_file", "list_directory", "search_files", "execute_command"],
      "code-skill": ["read_file", "write_file", "list_directory", "search_files", "execute_command"],
      "skill-document": ["read_file", "write_file", "list_directory", "search_files"],
      "document-skill": ["read_file", "write_file", "list_directory", "search_files"],
      "skill-search": ["search_files", "list_directory", "read_file"],
      "search-skill": ["search_files", "list_directory", "read_file"],
      "skill-file": ["read_file", "write_file", "list_directory", "search_files", "create_directory", "delete_file"],
      "file-skill": ["read_file", "write_file", "list_directory", "search_files", "create_directory", "delete_file"]
    }
  },
  "llm": {
    "provider": "openai",
    "apiKey": "",
    "baseUrl": "https://api.openai.com/v1",
    "defaultModel": "gpt-4",
    "defaultTemperature": 0.7,
    "timeout": 60000,
    "maxRetries": 3,
    "retry": {
      "step": {
        "maxRetries": 3,
        "initialDelayMs": 100,
        "maxDelayMs": 2000,
        "backoffMultiplier": 2
      },
      "task": {
        "maxRetries": 5,
        "initialDelayMs": 100,
        "maxDelayMs": 2000,
        "backoffMultiplier": 2
      }
    }
  },
  "scheduler": {
    "scanIntervalMs": 5000,
    "batchSize": 50,
    "scanTimeoutMs": 60000,
    "backoffMaxMs": 30000
  },
  "execution": {
    "maxConcurrentTasks": 3,
    "stepTimeoutMs": 300000,
    "maxRetries": 3
  },
  "attachment": {
    "maxSizeBytes": 52428800,
    "allowedTypes": ["image/*", "application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "text/plain"],
    "maxSliceLength": 2000,
    "sliceOverlap": 100,
    "ocr": {
      "enabled": false,
      "api": "tesseract"
    }
  },
  "orchestration": {
    "maxReplanCount": 3
  },
  "log": {
    "level": "info"
  }
}
