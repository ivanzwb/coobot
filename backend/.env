# Server Configuration
PORT=3001
NODE_ENV=development

# Workspace Configuration
WORKSPACE_PATH=

# Database
DB_PATH=./data/biosbot.db

# Vector Database
VECTOR_DB_PATH=./data/lancedb

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Security
AUTH_TIMEOUT_MINUTES=10

# Logging
LOG_LEVEL=info